# 复制为 .env 后填写（不要提交 .env）
PORT=8090

# 逗号分隔，生产填正式域名
CORS_ORIGINS=http://localhost:10086,http://localhost:10087,http://localhost:10088,https://admin.example.com

# 鉴权（生产务必更换随机字符串）
JWT_SECRET=change-me-in-production

# 消费者小程序
WECHAT_CONSUMER_APP_ID=
WECHAT_CONSUMER_APP_SECRET=

# 作业端小程序
WECHAT_WORKER_APP_ID=
WECHAT_WORKER_APP_SECRET=

# 微信支付商户号
WECHAT_MCH_ID=
WECHAT_MCH_API_KEY=
WECHAT_PAY_NOTIFY_URL=https://api.example.com/api/v1/pay/notify

# 数据库（持久化阶段启用）
# DATABASE_URL=mysql://user:pass@localhost:3306/neighbrohub

# 管理后台默认账号（生产请禁用或改密）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
