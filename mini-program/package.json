{
  "name": "neighbrohub",
  "version": "2.0.0",
  "description": "NeighbroHub - 社区私域购物平台 (积分系统+团长+楼长双级分销)",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "build:h5": "taro build --type h5",
    "dev:weapp": "npm run build:weapp -- --watch",
    "dev:h5": "npm run build:h5 -- --watch",
    "generate:icons": "python3 scripts/generate-icons.py",
    "test:icons": "node scripts/test-icons.js",
    "test:ui": "npm run test:icons && npm run build:weapp"
  },
  "dependencies": {
    "@tarojs/components": "^3.6.0",
    "@tarojs/helper": "^3.6.0",
    "@tarojs/plugin-framework-react": "^3.6.0",
    "@tarojs/plugin-platform-weapp": "^3.6.0",
    "@tarojs/plugin-platform-h5": "^3.6.0",
    "@tarojs/react": "^3.6.0",
    "@tarojs/runtime": "^3.6.0",
    "@tarojs/shared": "^3.6.0",
    "@tarojs/taro": "^3.6.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.8.0",
    "@tarojs/cli": "^3.6.0",
    "@tarojs/webpack5-runner": "^3.6.0",
    "@types/react": "^18.0.0",
    "babel-preset-taro": "^3.6.0",
    "eslint": "^8.12.0",
    "eslint-config-taro": "^3.6.0",
    "typescript": "^5.0.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.11",
    "webpack-dev-server": "^4.15.0"
  },
  "overrides": {
    "webpack": "5.88.2"
  }
}
